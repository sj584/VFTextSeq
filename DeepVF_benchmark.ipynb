        "import numpy as np\n",
        "import pandas as pd\n",
        "from xgboost import XGBClassifier\n",
        "from sklearn.metrics import roc_auc_score, accuracy_score, f1_score, precision_score, recall_score, matthews_corrcoef\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# Assuming binary classification (y_train, y_test are 0/1 arrays)\n",
        "# Create All features: concatenate ESM and Text horizontally\n",
        "X_train_all = np.hstack((X_train_esm, X_train_text))\n",
        "X_test_all = np.hstack((X_test_esm, X_test_text))\n",
        "\n",
        "# Ablation configurations\n",
        "configs = {\n",
        "    'ESM2': (X_train_esm, X_test_esm),\n",
        "    'Biotext': (X_train_text, X_test_text),\n",
        "    'VFTextSeq': (X_train_all, X_test_all)\n",
        "}\n",
        "\n",
        "results = {}\n",
        "for name, (X_tr, X_te) in configs.items():\n",
        "    print(f\"Training {name} (train shape: {X_tr.shape}, test shape: {X_te.shape})\")\n",
        "    \n",
        "    model = XGBClassifier(\n",
        "        random_state=42,\n",
        "        use_label_encoder=False,\n",
        "        eval_metric='auc'\n",
        "    )\n",
        "    model.fit(X_tr, y_train)\n",
        "    \n",
        "    y_pred = model.predict(X_te)\n",
        "    y_proba = model.predict_proba(X_te)[:, 1]\n",
        "    \n",
        "    metrics = {\n",
        "        'AUC-ROC': roc_auc_score(y_test, y_proba),\n",
        "        'Accuracy': accuracy_score(y_test, y_pred),\n",
        "        'F1': f1_score(y_test, y_pred),\n",
        "        'Precision': precision_score(y_test, y_pred),\n",
        "        'Recall': recall_score(y_test, y_pred),\n",
        "        'MCC': matthews_corrcoef(y_test, y_pred)\n",
        "    }\n",
        "    results[name] = metrics\n",
        "\n",
        "# Print results table\n",
